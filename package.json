{
  "name": "@tecsafe/widget-sdk",
  "repository": "https://github.com/TECSAFE/widget-sdk",
  "version": "0.0.0",
  "description": "Tecsafe Widget SDK for automated IFrame and JWT management",
  "private": false,
  "source": "src/index.ts",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@parcel/packager-ts": "2.12.0",
    "@parcel/transformer-typescript-types": "2.12.0",
    "@types/jest": "^30.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "parcel": "^2.12.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typedoc": "^0.26.6",
    "typedoc-plugin-merge-modules": "^6.0.0",
    "typescript": "^5.5.4"
  },
  "scripts": {
    "build": "parcel build",
    "doc": "typedoc",
    "test": "jest",
    "lint": "prettier \"src/**/*.ts\" \"test/**/*.ts\" --check",
    "lint:fix": "prettier \"src/**/*.ts\" \"test/**/*.ts\" --write"
  },
  "targets": {
    "main": {
      "includeNodeModules": true,
      "optimize": true
    }
  },
  "alias": {
    "jose": false
  }
}
